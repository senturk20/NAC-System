# ============================================================
# NACSystem Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your own secret values in .env
#   3. NEVER commit the .env file to git!
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=nac_admin
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_password
POSTGRES_DB=nac_db

# --- Redis ---
# Password that Redis will require for connections
REDIS_PASSWORD=CHANGE_ME_to_a_strong_redis_password

# --- FreeRADIUS ---
# Shared secret between RADIUS clients (switches/APs) and the RADIUS server
RADIUS_SECRET=CHANGE_ME_to_a_strong_radius_secret

# --- FastAPI / Policy Engine ---
# Secret key used for signing JWT tokens
API_SECRET_KEY=CHANGE_ME_to_a_random_secret_key
# Database connection string (references the postgres credentials above)
DATABASE_URL=postgresql://nac_admin:CHANGE_ME_to_a_strong_password@postgres:5432/nac_db
# Redis connection string
REDIS_URL=redis://:CHANGE_ME_to_a_strong_redis_password@redis:6379/0
